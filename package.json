{
  "name": "astro-theme-cactus",
  "version": "4.3.0",
  "private": false,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/generate-agent-content.mjs",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build && wrangler deploy --env staging",
    "wrangler": "wrangler",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "astro check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:prose": "corepack pnpm dlx @vvago/vale -- src/",
    "test:hooks": "bash scripts/codex-closeout-hook.test.sh",
    "skills:sync": "node scripts/sync-skills.mjs"
  },
  "dependencies": {
    "@astro-community/astro-embed-youtube": "0.5.10",
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/mdx": "7.0.1",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@types/hast": "3.0.4",
    "@types/mdast": "4.0.4",
    "@wooorm/starry-night": "3.10.0",
    "astro": "7.1.0",
    "astro-analytics": "2.7.0",
    "astro-expressive-code": "0.44.0",
    "astro-icon": "1.1.5",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "geist": "1.7.2",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-external-links": "3.0.0",
    "rehype-raw": "7.0.0",
    "remark-directive": "4.0.0",
    "satori": "0.26.0",
    "satori-html": "0.3.2",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@flydotio/dockerfile": "0.7.10",
    "@iconify-json/mdi": "1.2.3",
    "@pagefind/default-ui": "1.5.2",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/typography": "0.5.20",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.5.2",
    "mdast-util-to-string": "4.0.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "pagefind": "1.5.2",
    "postcss": "8.5.16",
    "postcss-html": "1.8.1",
    "postcss-import": "16.1.1",
    "reading-time": "1.5.0",
    "remark-unwrap-images": "4.0.1",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.8.0"
}
