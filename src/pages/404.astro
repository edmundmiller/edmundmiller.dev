---
import PageLayout from '@/layouts/base.astro';

const _meta = {
  description:
    'This page was not found. Use the site navigation to find Edmund Miller posts, talks, and bioinformatics notes.',
  robots: 'noindex, follow',
  title: 'Oops! You found a missing page!',
};
---

<PageLayout meta={_meta}>
  <h1 class="title mb-6">404 | Oops something went wrong</h1>
  <p class="mb-8">Please use the navigation to find your way back</p>
  <div class="my-4 grid justify-center">
    <img
      alt="A juggler doing the boston mess pattern"
      loading="eager"
      src="https://libraryofjuggling.com/JugglingGifs/3balltricks/bostonmess.gif"
    />
  </div>
</PageLayout>
