---
import { siteConfig } from '@/site-config';
import type { SiteMeta } from '@/types';

import '../styles/global.css';

type Props = SiteMeta;

const { articleDate, description, ogImage, title, canonical, robots } =
  Astro.props as Props;

const titleSeparator = '|';
const _siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`;
const _canonicalURL = canonical
  ? new URL(canonical)
  : new URL(Astro.url.pathname, Astro.site);
const _socialImageURL = new URL(
  ogImage ? ogImage : '/social-card.png',
  Astro.url
).href;
---

<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0, shrink-to-fit=no" name="viewport" />
<meta content="IE=edge" http-equiv="X-UA-Compatible" />
<title>{_siteTitle}</title>

{/* Icons / Favicon */}
<link href="/favicon.ico" rel="icon" sizes="any" />
<link href="/icon.svg" rel="icon" type="image/svg+xml" />
<link href="/apple-touch-icon.png" rel="apple-touch-icon" />
<link href="/manifest.webmanifest" rel="manifest" />
<link href={_canonicalURL} rel="canonical" />

{/* Geist Pixel Fonts */}
<link rel="preload" href="/fonts/geist-pixel/GeistPixel-Square.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/geist-pixel/GeistPixel-Grid.woff2" as="font" type="font/woff2" crossorigin />

{/* Primary Meta Tags */}
<meta content={_siteTitle} name="title" />
<meta content={description} name="description" />
<meta content={siteConfig.author} name="author" />
{robots && <meta content={robots} name="robots" />}

{/* Theme Colour */}
<meta content="" name="theme-color" />

{/* Open Graph / Facebook */}
<meta content={articleDate ? "article" : "website"} property="og:type" />
<meta content={title} property="og:title" />
<meta content={description} property="og:description" />
<meta content={_canonicalURL} property="og:url" />
<meta content={siteConfig.title} property="og:site_name" />
<meta content={siteConfig.ogLocale} property="og:locale" />
<meta content={_socialImageURL} property="og:image" />
<meta content="1200" property="og:image:width" />
<meta content="630" property="og:image:height" />
{
  articleDate && (
    <>
      <meta content={siteConfig.author} property="article:author" />
      <meta content={articleDate} property="article:published_time" />
    </>
  )
}

{/* Twitter */}
<meta content="summary_large_image" property="twitter:card" />
<meta content={_canonicalURL} property="twitter:url" />
<meta content={title} property="twitter:title" />
<meta content={description} property="twitter:description" />
<meta content={_socialImageURL} property="twitter:image" />

{/* Sitemap */}
<link href="/sitemap-index.xml" rel="sitemap" />

{/* RSS auto-discovery */}
<link href="/rss.xml" rel="alternate" title={siteConfig.title} type="application/rss+xml" />

{/* Webmentions */}
{
  siteConfig.webmentions && (
    <>
      <link href={siteConfig.webmentions.link} rel="webmention" />
      {siteConfig.webmentions.pingback && (
        <link href={siteConfig.webmentions.pingback} rel="pingback" />
      )}
    </>
  )
}

<meta content={Astro.generator} name="generator" />

{/* Analytics */}
<script is:inline data-goatcounter="https://emiller.goatcounter.com/count" async src="//gc.zgo.at/count.js"
></script>
<script is:inline>
  (() => {
    const clean = (value) =>
      value
        ?.toString()
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "")
        .slice(0, 80) || "unknown";

    const titleFor = (element, fallback) =>
      element?.getAttribute("aria-label") ||
      element?.textContent?.trim().replace(/\s+/g, " ").slice(0, 120) ||
      fallback;

    const track = (path, title) => {
      if (!window.goatcounter?.count) {
        return;
      }

      window.goatcounter.count({
        event: true,
        path,
        title,
      });
    };

    document.addEventListener("click", (event) => {
      const target = event.target instanceof Element ? event.target : null;

      if (!target) {
        return;
      }

      const searchResult = target.closest("#cactus__search .pagefind-ui__result-link");
      if (searchResult) {
        track("event:site-search:result-click", "Site search result click");
        return;
      }

      const explicitEvent = target.closest("[data-goatcounter-event]");
      if (explicitEvent) {
        const eventName = explicitEvent.getAttribute("data-goatcounter-event");
        track(`event:cta:${clean(eventName)}`, titleFor(explicitEvent, "CTA click"));
        return;
      }

      const link = target.closest("a[href]");
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      const url = new URL(link.href, window.location.href);
      const isWebLink = url.protocol === "http:" || url.protocol === "https:";
      const isOutbound = isWebLink && url.origin !== window.location.origin;
      const isEmail = url.protocol === "mailto:";

      if (isOutbound || isEmail) {
        const destination = isEmail ? "mailto" : url.hostname;
        track(`event:outbound:${clean(destination)}`, titleFor(link, link.href));
      }
    });

    document.addEventListener(
      "submit",
      (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) {
          return;
        }

        const explicitEvent =
          form.getAttribute("data-goatcounter-event") ||
          form.getAttribute("data-goatcounter-form");

        if (explicitEvent) {
          track(`event:form:${clean(explicitEvent)}`, titleFor(form, "Form submission"));
          return;
        }

        if (form.closest("#cactus__search") || form.classList.contains("pagefind-ui__form")) {
          track("event:site-search:submit", "Site search submit");
          return;
        }

        track("event:form:submit", titleFor(form, "Form submission"));
      },
      true
    );
  })();
</script>
